# =============================================================================
# FreelanceCFO — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=freelancecfo
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=freelancecfo_db

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://freelancecfo:CHANGE_ME_strong_password_here@db:5432/freelancecfo_db
REDIS_URL=redis://redis:6379/0

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

ENVIRONMENT=development   # or: production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# GitHub username — used to pull images from GHCR
# Must match your GitHub account (github.com/YOUR_USERNAME)
GITHUB_OWNER=YOUR_GITHUB_USERNAME

# Frontend origin — used in CORS and email links
# Dev:  http://localhost:3000
# Prod (IP): http://13.53.56.157
# Prod (domain, when you have one): https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Admin UIs (dev only — not included in prod compose)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=CHANGE_ME_admin_password

# -----------------------------------------------------------------------------
# Google Gemini (AI categorization + CFO chat)
# Get key: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Stripe Connect (payments)
# Test keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: create in dashboard > Developers > Webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# -----------------------------------------------------------------------------
# SendGrid (email delivery)
# Get key: https://app.sendgrid.com/settings/api_keys
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=

# -----------------------------------------------------------------------------
# AWS S3 (invoice PDF storage)
# Leave blank to use on-the-fly PDF generation (no S3 needed for dev)
# Prod: use IAM instance role instead of access keys
# -----------------------------------------------------------------------------
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Telegram Bot
# Create a bot: https://t.me/BotFather → /newbot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
